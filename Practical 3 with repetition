#include <iostream>
#include <vector>
using namespace std;

void permuteRep(vector<int> &a, vector<int> &res, int n, int k) {
    if (k == 0) {
        for (int x : res) cout << x << " ";
        cout << endl;
        return;
    }

    for (int i = 0; i < n; i++) {
        res.push_back(a[i]);
        permuteRep(a, res, n, k - 1);
        res.pop_back();
    }
}

int main() {
    vector<int> a = {1, 2, 3};
    vector<int> res;
    int length = 3;

    permuteRep(a, res, a.size(), length);
    return 0;
}
