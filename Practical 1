#include <iostream>
using namespace std;

class SET{
public:
    int a[10], n;

    void in(int x){ n=x; for(int i=0;i<n;i++) cin>>a[i]; }

    bool isMember(int x){
        for(int i=0;i<n;i++) if(a[i]==x) return true;
        return false;
    }

    void powerSet(){
        for(int i=0;i<(1<<n);i++){
            cout<<"{ ";
            for(int j=0;j<n;j++)
                if(i&(1<<j)) cout<<a[j]<<" ";
            cout<<"}\n";
        }
    }

    bool subset(SET b){
        for(int i=0;i<n;i++){
            bool f=0;
            for(int j=0;j<b.n;j++)
                if(a[i]==b.a[j]) f=1;
            if(!f) return false;
        }
        return true;
    }

    void uni(SET b){
        for(int i=0;i<n;i++) cout<<a[i]<<" ";
        for(int i=0;i<b.n;i++){
            bool f=0;
            for(int j=0;j<n;j++)
                if(b.a[i]==a[j]) f=1;
            if(!f) cout<<b.a[i]<<" ";
        }
        cout<<endl;
    }

    void inter(SET b){
        for(int i=0;i<n;i++)
            for(int j=0;j<b.n;j++)
                if(a[i]==b.a[j]) cout<<a[i]<<" ";
        cout<<endl;
    }

    void comp(SET u){
        for(int i=0;i<u.n;i++){
            bool f=0;
            for(int j=0;j<n;j++)
                if(u.a[i]==a[j]) f=1;
            if(!f) cout<<u.a[i]<<" ";
        }
        cout<<endl;
    }

    void diff(SET b){
        for(int i=0;i<n;i++){
            bool f=0;
            for(int j=0;j<b.n;j++)
                if(a[i]==b.a[j]) f=1;
            if(!f) cout<<a[i]<<" ";
        }
        cout<<endl;
    }

    void sym(SET b){
        diff(b);
        b.diff(*this);
    }

    void cart(SET b){
        for(int i=0;i<n;i++)
            for(int j=0;j<b.n;j++)
                cout<<"("<<a[i]<<","<<b.a[j]<<") ";
        cout<<endl;
    }
};

int main(){
    SET A,B,U;
    int n,m,u,ch,x;

    cin>>n; A.in(n);
    cin>>m; B.in(m);
    cin>>u; U.in(u);

    do{
        cout<<"\n1.Member 2.PowerSet 3.Subset 4.Union 5.Intersection\n";
        cout<<"6.Complement 7.Difference 8.Symmetric 9.Cartesian 0.Exit\n";
        cin>>ch;

        switch(ch){
            case 1: cin>>x;
                    cout<<(A.isMember(x)?"Yes":"No"); break;
            case 2: A.powerSet(); break;
            case 3: cout<<(A.subset(B)?"Subset":"Not"); break;
            case 4: A.uni(B); break;
            case 5: A.inter(B); break;
            case 6: A.comp(U); break;
            case 7: A.diff(B); break;
            case 8: A.sym(B); break;
            case 9: A.cart(B); break;
        }
    }while(ch!=0);
}
