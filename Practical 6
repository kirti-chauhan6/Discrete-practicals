#include <stdio.h>

int main() {
    int n, i, j, f = 1;
    scanf("%d", &n);
    int a[n][n];

    for(i = 0; i < n; i++)
        for(j = 0; j < n; j++)
            scanf("%d", &a[i][j]);

    for(i = 0; i < n; i++)
        for(j = 0; j < n; j++)
            if((i == j && a[i][j] != 0) || (i != j && a[i][j] != 1))
                f = 0;

    if(f) printf("Complete Graph");
    else printf("Not Complete Graph");

    return 0;
}
