#include <iostream>
using namespace std;

int main() {
    int n = 5;
    int coeff[] = {4, 2, 9}; 
    int result = 0;

    int degree = 2;

    for (int i = 0; i <= degree; i++) {
        result += coeff[i] * pow(n, degree - i);
    }

    cout << "Value of polynomial = " << result;

    return 0;
}
