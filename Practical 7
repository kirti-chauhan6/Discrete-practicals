#include <stdio.h>

int main() {
    int n, i, j;
    scanf("%d", &n);
    int a[n][n], in[n], out[n];

    for(i = 0; i < n; i++) {
        in[i] = out[i] = 0;
        for(j = 0; j < n; j++)
            scanf("%d", &a[i][j]);
    }

    for(i = 0; i < n; i++)
        for(j = 0; j < n; j++) {
            out[i] += a[i][j];
            in[j] += a[i][j];
        }

    for(i = 0; i < n; i++)
        printf("Vertex %d: In=%d Out=%d\n", i, in[i], out[i]);

    return 0;
}
