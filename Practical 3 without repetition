#include <iostream>
#include <vector>
using namespace std;

void permute(vector<int> &a, int l, int r) {
    if (l == r) {
        for (int x : a) cout << x << " ";
        cout << endl;
        return;
    }

    for (int i = l; i <= r; i++) {
        swap(a[l], a[i]);
        permute(a, l + 1, r);
        swap(a[l], a[i]);
    }
}

int main() {
    vector<int> a = {1, 2, 3};
    permute(a, 0, a.size() - 1);
    return 0;
}
